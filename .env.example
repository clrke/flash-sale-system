# Backend configuration (copy to .env; all values are optional and have sane defaults)

# HTTP
PORT=3000
HOST=0.0.0.0

# Inventory store: "memory" (default, zero dependencies) or "redis"
STORE=memory
REDIS_URL=redis://localhost:6379

# Product on sale (display only; all optional). The default image is a real
# photo bundled with the frontend at packages/frontend/public/product.jpg, so
# the demo shows an actual product image with no external dependency. Set
# PRODUCT_IMAGE_URL to any absolute URL to front a different product.
PRODUCT_NAME=Aurora Wireless Headphones
PRODUCT_TAGLINE=Studio-grade sound, 40-hour battery, strictly limited drop.
PRODUCT_PRICE=$149
PRODUCT_IMAGE_URL=/product.jpg

# Flash sale parameters
TOTAL_STOCK=5
# ISO 8601 timestamps. If omitted, the sale starts now and runs for SALE_DURATION_MS.
SALE_START=
SALE_END=
SALE_DURATION_MS=180000

# Testing/demo only: enables POST /api/sale/reset, which restarts the sale
# clock and refills stock on demand. Unauthenticated, so it defaults off -
# only turn this on for local iteration or a live walkthrough, never in a
# real deployment.
ENABLE_RESET_API=
